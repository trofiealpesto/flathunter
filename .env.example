# Shared
NODE_ENV=development
DATABASE_URL=postgres://postgres:postgres@localhost:5432/flathunter
APP_ORIGIN=http://localhost:3000

# API
PORT=4000
SESSION_SECRET=replace-me-with-a-long-random-secret
ADMIN_GITHUB_LOGIN=your-github-login
GITHUB_CLIENT_ID=replace-me
GITHUB_CLIENT_SECRET=replace-me
ENABLE_MANUAL_SOURCE_AUTH_BOOTSTRAP=true
PORTAL_SECRETS_KEY=replace-with-32-plus-random-chars

# Web / Vercel proxy
VITE_APP_NAME=FlatHunter
VITE_DEV_API_ORIGIN=http://localhost:4000
API_ORIGIN=http://localhost:4000

# Worker
GEMINI_API_KEY=
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_CLASSIFIER_MAX_PER_RUN=4
GEMINI_CLASSIFIER_FALLBACK_MAX_PER_RUN=1
GEMINI_CLASSIFIER_MIN_DELAY_MS=8000
GEMINI_CLASSIFIER_RETRY_COOLDOWN_MS=1800000
IMMOWELT_SEARCH_URL=https://www.immowelt.de/liste/berlin/wohnungen/mieten
IMMOWELT_ENABLE_LIVE_BROWSER=true
WORKER_DEV_INTERVAL_MS=300000
SCRAPER_PROXY_URL=
CAPSOLVER_API_KEY=

# Production notes
# APP_ORIGIN=https://<your-vercel-domain>
# API_ORIGIN=https://<your-api-service-domain>
# ENABLE_MANUAL_SOURCE_AUTH_BOOTSTRAP=false
