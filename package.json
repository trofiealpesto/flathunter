{
  "name": "flathunter",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "build": "pnpm --filter @flathunter/web run build && pnpm --filter @flathunter/api run build && pnpm --filter @flathunter/worker run build",
    "dev": "pnpm -r --parallel --filter @flathunter/api --filter @flathunter/web --filter @flathunter/worker run dev",
    "dev:api": "pnpm --filter @flathunter/api run dev",
    "dev:web": "pnpm --filter @flathunter/web run dev",
    "dev:worker": "pnpm --filter @flathunter/worker run dev",
    "worker:dev": "pnpm --filter @flathunter/worker run start:loop",
    "test": "pnpm -r run test",
    "typecheck": "pnpm -r run typecheck",
    "db:migrate": "pnpm --filter @flathunter/db run migrate",
    "worker:run": "pnpm --filter @flathunter/worker run start",
    "worker:benchmark:llm": "pnpm --filter @flathunter/worker run benchmark:llm"
  },
  "devDependencies": {
    "@types/node": "^24.8.1",
    "tsup": "^8.5.0",
    "tsx": "^4.20.6",
    "typescript": "^6.0.2",
    "vitest": "^2.1.9"
  }
}
