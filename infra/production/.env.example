# Generic self-hosted production env
NODE_ENV=production

# Public web origin used by GitHub OAuth callbacks.
# When using make prod-deploy, this is overridden by PROD_APP_ORIGIN,
# derived from PROD_SCHEME, PROD_HOST, and PROD_PORT unless set explicitly.
APP_ORIGIN=http://localhost

# Postgres runs inside docker-compose by default.
POSTGRES_DB=flathunter
POSTGRES_USER=flathunter
POSTGRES_PASSWORD=replace-with-a-long-random-password
DATABASE_URL=postgres://flathunter:replace-with-a-long-random-password@postgres:5432/flathunter

# API
PORT=4000
SESSION_SECRET=replace-with-a-long-random-secret
PORTAL_SECRETS_KEY=replace-with-32-plus-random-chars
ADMIN_GITHUB_LOGIN=your-github-login
GITHUB_CLIENT_ID=replace-me
GITHUB_CLIENT_SECRET=replace-me
ENABLE_MANUAL_SOURCE_AUTH_BOOTSTRAP=false
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
SCRAPER_PROXY_URL=

# Worker
IMMOWELT_SEARCH_URL=https://www.immowelt.de/liste/berlin/wohnungen/mieten
IMMOWELT_ENABLE_LIVE_BROWSER=true
WORKER_DEV_INTERVAL_MS=300000
CAPSOLVER_API_KEY=
GEMINI_API_KEY=
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_CLASSIFIER_MAX_PER_RUN=4
GEMINI_CLASSIFIER_MIN_DELAY_MS=8000
GEMINI_CLASSIFIER_RETRY_COOLDOWN_MS=1800000
